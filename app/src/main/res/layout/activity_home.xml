<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title: BERANDA -->
        <TextView
            android:id="@+id/tvHomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BERANDA"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#202124"
            android:layout_marginBottom="16dp"/>

        <!-- Subtitle: Selamat datang di aplikasi! -->
        <TextView
            android:id="@+id/tvWelcomeDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang di aplikasi!"
            android:textSize="16sp"
            android:textColor="#5F6368"
            android:layout_marginBottom="20dp"/>

        <!-- Main Banner Image -->
        <ImageView
            android:id="@+id/img_banner"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/img_home_banner"
            android:scaleType="centerCrop"
            android:background="#E8EAED"
            android:contentDescription="Banner Sport Center"
            android:layout_marginBottom="16dp"/>

        <!-- Member Info Card (OOP Display) -->
        <LinearLayout
            android:id="@+id/card_member"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Member: Muhamad Ihsan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#202124" />

            <TextView
                android:id="@+id/tvMemberSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo: Rp 150.000"
                android:textSize="15sp"
                android:textColor="#1A73E8"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Court Details Card (Lapangan OOP) -->
        <LinearLayout
            android:id="@+id/card_lapangan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvLapanganTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lapangan A - Badminton"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#202124" />

            <TextView
                android:id="@+id/tvLapanganHarga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga Sewa: Rp 50.000 / Sesi"
                android:textSize="14sp"
                android:textColor="#D93025"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvLapanganJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jadwal: 08:00 - 10:00 (Tersedia)"
                android:textSize="13sp"
                android:textColor="#5F6368"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <!-- Booking buttons -->
            <Button
                android:id="@+id/btnCekKetersediaan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cek Ketersediaan"
                android:backgroundTint="#34A853"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnPesanLapangan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booking Sekarang"
                android:backgroundTint="#1A73E8"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnTopUp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top Up Saldo +Rp 50.000"
                android:backgroundTint="#82B366"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnBatalkanBooking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Batalkan Booking"
                android:backgroundTint="#F8CECC"
                android:textColor="#B85450" />
        </LinearLayout>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:backgroundTint="#D93025"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
